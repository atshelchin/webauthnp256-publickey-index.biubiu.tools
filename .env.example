# Service port
PORT=11256

# Queue database path
QUEUE_DB_PATH=queue.db

# Server wallet private key (for on-chain transactions).
# Must be a 0x-prefixed 32-byte (64 hex char) key; startup fails fast otherwise.
PRIVATE_KEY=0x...

# Optional priority write RPC (also honored by the CF Worker).
ALCHEMY_API_KEY=

# Background queue worker. Defaults ON. Set to 0 to run READ-ONLY (no on-chain
# signing) — the `dev` task sets this so a dev machine never becomes a live
# mainnet signer. Leave UNSET in production.
QUEUE_WORKER=1

# In-memory cache budget in MB (default 32). Keep well under the process cap.
CACHE_MAX_MB=32

# Global create cap per minute across ALL clients (default 40 — matched to the
# pipeline's drain rate so a flood can't build an hours-long backlog).
GLOBAL_WRITE_LIMIT=40

# Minimum log level: debug | info | warn | error (default debug)
LOG_LEVEL=info

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
